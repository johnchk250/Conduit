# Windows/Linux desktop build output (flutter build windows/linux lands here
# too, but this repo's own /build/ rule above already covers the top-level
# case — these cover any nested ones from local experiments)
**/windows/flutter/ephemeral/
**/windows/flutter/generated_plugin_registrant.*
**/windows/flutter/generated_plugins.cmake
**/linux/flutter/ephemeral/
**/linux/flutter/generated_plugin_registrant.*
**/linux/flutter/generated_plugins.cmake

# Project-specific: diagnostic capture output from capture_pc.bat /
# capture_android.bat — timestamped logs, not something to version.
/logs/

# Signing / secrets — never commit these even if you create them locally
*.keystore
.env
